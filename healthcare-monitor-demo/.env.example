# Copy to .env on the Brev/runtime host only. Do not commit .env.
# NemoClaw provider "custom" is the Other OpenAI-compatible endpoint option.
NEMOCLAW_PROVIDER_KEY=
NEMOCLAW_ENDPOINT_URL=https://inference-api.nvidia.com/v1/chat/completions
NEMOCLAW_SANDBOX=healthcare-monitor
NEMOCLAW_PROVIDER=custom
NEMOCLAW_MODEL=nvidia/nvidia/nemotron-3-super-v3

# Recommended enterprise pilot posture: start restricted, then add explicit policy.
NEMOCLAW_POLICY_TIER=restricted
NEMOCLAW_POLICY_MODE=suggested

# Optional setup controls.
NEMOCLAW_INSTALL_IF_MISSING=0
NEMOCLAW_ACCEPT_THIRD_PARTY_SOFTWARE=1
NEMOCLAW_DESTROY_EXISTING=0
NEMOCLAW_APPLY_LOCAL_POLICY=1

# Optional web app settings.
HOST=127.0.0.1
PORT=5188
